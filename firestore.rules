rules_version = '2';

// ════════════════════════════════════════════════════════════════════
//  REGLAS DE SEGURIDAD — Circanícula (Firestore) · ESQUEMA DE RANGOS v2
//  Cómo aplicar:
//    Firebase Console → proyecto circanicula-267 → Firestore Database →
//    pestaña "Reglas" → pega TODO esto → "Publicar".
//
//  ⚠️  ORDEN DE PUESTA EN MARCHA (evita escalada de privilegios):
//    1) Despliega el código nuevo (GitHub Pages).
//    2) Entra como Dueño → panel admin → "Migrar rangos" (recorre nuevo=viejo+1).
//       Esto corre con las reglas VIEJAS aún publicadas (el Dueño/super-admin
//       puede reescribir rangos). Es seguro: solo degrada, no escala.
//    3) Publica ESTAS reglas. Recién entonces los números nuevos cobran su
//       nuevo significado. (Migrar DESPUÉS de publicar sí escalaría: un viejo
//       Rank 1 "Instructora" se leería como "Administración".)
//
//  ESQUEMA v2 (número = poder; menor = más poder):
//     0 Dueño · 1 Administración · 2 Instructora · 3 Asistente · 4 Alumno · 5 Viewer
//
//  Principios:
//   • Créditos (Estrellas): NADIE los edita desde el cliente (ni el Dueño).
//     Inmutables hasta que exista un backend/Cloud Function que los otorgue.
//   • rank: solo el Dueño (Rank 0 / super-admin) lo cambia.
//   • imparteClases / colaborador: ETIQUETAS de rol curadas por admin (Rank ≤ 1).
//     El propio dueño del perfil solo puede inicializarlas en false (anti-autoascenso).
//   • nivel/títulos/eventos (stats RPG): los otorgan Instructoras/Admin/Dueño (Rank ≤ 2).
//   • Correo: NO se guarda en Firestore (vive solo en Firebase Auth).
//   • Teléfono (usuarios_priv): el dueño y el staff de clase (Rank ≤ 2).
//   • Pagos/reservas: privados del dueño (el staff de clase los ve para agenda).
// ════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    // Alta por defecto (Alumno). Debe coincidir con RANK_DEFAULT del index.html.
    function rankDefault() { return 4; }

    // ════════════════════════════════════════════════════════════════════
    //  MULTI-TENANT (modelo: UN PROYECTO FIREBASE POR ACADEMIA)
    //  Cada academia tiene su PROPIO proyecto Firebase → su PROPIA base, su
    //  PROPIO Auth y su PROPIA copia de estas reglas. El aislamiento entre
    //  academias es TOTAL por diseño (bases separadas).
    //  ⚠️  AL DAR DE ALTA UNA ACADEMIA NUEVA: cambia el correo de abajo por el
    //      del super-admin (Rank 0 / Dueño) de ESA academia. Es la ÚNICA línea a tocar.
    // ════════════════════════════════════════════════════════════════════
    function superAdminEmail() { return 'treseenicos@gmail.com'; } // ← SWAP por tenant

    // El super-admin (Dueño) se identifica por su correo verificado en el token.
    function isSuperAdmin() {
      return signedIn() && request.auth.token.email == superAdminEmail();
    }

    function rankDoc(uid) {
      return get(/databases/$(database)/documents/usuarios/$(uid)).data.rank;
    }
    function myRank() {
      return (signedIn() &&
              exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)))
             ? rankDoc(request.auth.uid) : 99;
    }

    // ── Jerarquía de poder (esquema v2) ──
    function isDueno()      { return isSuperAdmin() || myRank() == 0; }            // Rank 0
    function isAdmin()      { return isDueno()  || myRank() == 1; }                // + Administración
    function isStaffClase() { return isAdmin()  || myRank() == 2; }               // + Instructoras

    // ¿Puedo editar el CALENDARIO de cierta persona (uid) con rank targetRank?
    //   • El Dueño (Rank 0) puede con cualquiera.
    //   • Cualquier staff (Rank ≤ 3) puede con SU PROPIO calendario.
    //   • Un staff con MÁS poder (número menor) puede con un subordinado de
    //     MENOS poder, siempre que ambos sean staff (≤ 3). Así: 0→1,2,3 ·
    //     1→2,3 · 2→3 · 3→solo el suyo. Nunca a un par ni a un superior.
    function puedeEditarCalendario(targetUid, targetRank) {
      return isDueno()
        || (myRank() <= 3 && targetUid == request.auth.uid)
        || (isStaffClase() && myRank() < targetRank && targetRank <= 3);
    }

    // Un campo no cambia, o se está inicializando por primera vez (no existía).
    function unchangedOrNew(field) {
      return !(field in resource.data) ||
             request.resource.data[field] == resource.data[field];
    }

    // Flag de rol (imparteClases/colaborador): SOLO lo cura un admin. El propio
    // dueño del perfil puede dejarlo igual o inicializarlo en false, pero NUNCA
    // ponérselo en true por su cuenta (anti-autoascenso a docente/colaborador).
    function selfFlagOk(field) {
      return !(field in request.resource.data)
             || ( (field in resource.data)
                    ? request.resource.data[field] == resource.data[field]
                    : request.resource.data[field] == false );
    }

    // ── PERFIL PÚBLICO ────────────────────────────────────────────────
    match /usuarios/{uid} {
      // Cualquier usuario autenticado puede leer perfiles públicos
      // (necesario para el directorio "Buscar Perfil" y la semblanza de misses).
      allow read: if signedIn();

      // Crear el propio perfil. Nadie se autoasigna privilegios: créditos en 0,
      // rank = Alumno (4) salvo el super-admin (que nace Dueño, Rank 0), y los
      // flags de rol nacen en false (no autoascenso a docente/colaborador).
      allow create: if isOwner(uid)
        && request.resource.data.creditos == 0
        && (isSuperAdmin() || request.resource.data.rank == rankDefault())
        && (!('imparteClases' in request.resource.data) || request.resource.data.imparteClases == false)
        && (!('colaborador'   in request.resource.data) || request.resource.data.colaborador   == false);

      // DUEÑO (Rank 0 / super-admin): edita cualquier perfil —incluido rank y los
      // flags de rol— pero NUNCA los créditos (solo backend/Cloud Function).
      allow update: if isDueno()
        && request.resource.data.creditos == resource.data.creditos
        && unchangedOrNew('creditosExpiran');

      // ADMINISTRACIÓN (Rank 1): gestiona perfiles (stats, títulos, eventos, flags
      // de rol, apodo, semblanza…), pero NO toca rank ni créditos. Tampoco
      // habilita/deshabilita cuentas (eso es exclusivo del Dueño).
      allow update: if isAdmin()
        && request.resource.data.rank == resource.data.rank
        && request.resource.data.creditos == resource.data.creditos
        && unchangedOrNew('creditosExpiran')
        && unchangedOrNew('cuentaActiva');

      // INSTRUCTORAS (Rank 2): otorgan stats RPG (nivel/títulos/eventos) y nada
      // más. No tocan rank, créditos, flags de rol ni IDs.
      allow update: if isStaffClase()
        && request.resource.data.rank == resource.data.rank
        && request.resource.data.creditos == resource.data.creditos
        && unchangedOrNew('creditosExpiran')
        && unchangedOrNew('imparteClases')
        && unchangedOrNew('colaborador')
        && unchangedOrNew('userIdCorto')
        && unchangedOrNew('handle')
        && unchangedOrNew('cuentaActiva');

      // DUEÑO DEL PERFIL (cualquier rank): solo lo suyo y solo lo cosmético
      // (nombreVisible, foto, especialidad, semblanza, colab, visibilidad…).
      // No rank, ni créditos, ni stats (nivel/títulos/eventos), ni IDs. Los flags
      // de rol solo puede inicializarlos en false. El apodo solo lo cambia el
      // staff (Rank ≤ 3: Dueño/Administración/Instructoras/Asistentes).
      allow update: if isOwner(uid)
        && request.resource.data.rank == resource.data.rank
        && request.resource.data.creditos == resource.data.creditos
        && unchangedOrNew('creditosExpiran')
        && unchangedOrNew('nivel')
        && unchangedOrNew('titulos')
        && unchangedOrNew('eventos')
        && unchangedOrNew('userIdCorto')
        && unchangedOrNew('handle')
        && selfFlagOk('imparteClases')
        && selfFlagOk('colaborador')
        && unchangedOrNew('cuentaActiva')
        && (request.resource.data.apodo == resource.data.apodo || myRank() <= 3);

      // ELIMINAR LA PROPIA CUENTA: cada quien puede borrar SU perfil (la opción
      // "Eliminar mi cuenta"). El Dueño NO se puede borrar a otro desde el cliente
      // (eso requiere Admin SDK); para "quitar" a un tercero usa cuentaActiva:false
      // (deshabilitar), que sí controla el Dueño vía las reglas update de arriba.
      allow delete: if isOwner(uid);
    }

    // ── DATOS PRIVADOS (teléfono) ─────────────────────────────────────
    // Lo leen y escriben el dueño y el staff de clase (Rank ≤ 2).
    match /usuarios_priv/{uid} {
      allow read, write: if isOwner(uid) || isStaffClase();
    }

    // ── CORREO DE RECUPERACIÓN (ultra-privado) ────────────────────────
    // Solo el DUEÑO del perfil lo lee/escribe. Ni el staff lo ve. El backend
    // (Cloud Function con admin SDK) lo leerá para enviar el link de reseteo
    // sin exponerlo nunca al cliente.
    match /usuarios_recuperacion/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── RESERVAS DE CLASES ────────────────────────────────────────────
    //  Estados: pendiente_pago → pago_reportado (el alumno DECLARA que pagó al
    //  volver de Stripe) → activa (la CONFIRMA el staff o el webhook, NUNCA el
    //  propio alumno) · cancelada.
    //  ⚠️ SEGURIDAD (P0): el dueño de la reserva NO puede ponerla en 'activa' por
    //  su cuenta — eso sería autoactivarse sin pagar. 'activa' es exclusivo del
    //  staff (Rank ≤ 2) o del backend (webhook de Stripe vía Admin SDK). El
    //  navegador es del usuario: estas reglas son la ÚNICA frontera real.
    match /reservas/{id} {
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isStaffClase());

      // Crear: SOLO a nombre propio, SOLO como 'pendiente_pago' y SIN marcas de
      // pago. Cierra el hueco de "crear la reserva ya activa".
      allow create: if isOwner(request.resource.data.uid)
        && request.resource.data.estado == 'pendiente_pago'
        && !('fechaPago' in request.resource.data);

      // STAFF (Rank ≤ 2): confirma el pago (→ 'activa'), cancela o gestiona.
      // No puede reasignar la reserva a otro uid ni alterar plan/clases.
      allow update: if isStaffClase()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.plan == resource.data.plan
        && request.resource.data.clases == resource.data.clases;

      // DUEÑO de la reserva: SOLO puede reportar su pago ('pago_reportado') o
      // cancelar la SUYA. NUNCA 'activa'. No toca uid/plan/clases y no puede
      // alterar una reserva que ya esté 'activa'.
      allow update: if isOwner(resource.data.uid)
        && resource.data.estado != 'activa'
        && request.resource.data.estado in ['pago_reportado', 'cancelada']
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.plan == resource.data.plan
        && request.resource.data.clases == resource.data.clases;

      allow delete: if isStaffClase();
    }

    // ── BOLETOS DE EVENTO (contador) ──────────────────────────────────
    match /boletos/{id} {
      allow read:   if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if isStaffClase();
    }

    // ── CALENDARIO DE HORARIOS DEL STAFF (Fase B) ─────────────────────
    //  Cada miembro del staff (Rank ≤ 3) publica sus horas de clase /
    //  disponibilidad. La JERARQUÍA de edición vive en puedeEditarCalendario().
    //  INMUTABILIDAD: una hora, una vez creada ("establecida"), NO se modifica
    //  en sitio (allow update:false). Para "cambiarla" se CANCELA (delete) y se
    //  vuelve a crear — así nadie reescribe un compromiso ya publicado.
    match /horarios/{id} {
      // La leen todas las personas autenticadas (los alumnos verán las clases
      // cuando llegue la fase de reservas).
      allow read: if signedIn();

      // Crear: el editor debe poder editar el calendario del uid objetivo, el
      // sello creadoPor debe ser él mismo, y el rank guardado debe COINCIDIR con
      // el rank real del objetivo (evita falsearlo para saltarse la jerarquía).
      allow create: if signedIn()
        && request.resource.data.creadoPor == request.auth.uid
        && request.resource.data.uid is string
        && request.resource.data.rank == rankDoc(request.resource.data.uid)
        && puedeEditarCalendario(request.resource.data.uid, request.resource.data.rank);

      // Inmutable: una hora establecida NO se modifica.
      allow update: if false;

      // Cancelar (borrar): el dueño de la hora, un rank de más poder, o el Dueño.
      allow delete: if signedIn()
        && ( resource.data.uid == request.auth.uid
             || isDueno()
             || (isStaffClase() && myRank() < resource.data.rank) );
    }

    // ── CUPO AGREGADO POR CLASE (T3-H) ────────────────────────────────
    //  cupos/{slotId} = { count, max, updatedAt }. Es un AGREGADO PÚBLICO para
    //  que el ALUMNO vea "lleno"/cupo SIN poder leer las reservas ajenas (su
    //  privacidad sigue intacta: solo lee SUS reservas). Lo recalcula y escribe
    //  el staff (Rank ≤ 2) desde las reservas reales (idempotente).
    match /cupos/{slotId} {
      allow read: if signedIn();
      // STAFF: recálculo libre e idempotente desde las reservas reales.
      allow create, update: if isStaffClase()
        && request.resource.data.count is int
        && request.resource.data.count >= 0;
      // ALUMNO (clase suelta): aparta SU lugar con un +1 ATÓMICO (transacción).
      // TOPE DURO de 6: el 7º intento (6 -> 7) lo rechaza esta regla aunque el
      // cliente fallara. No puede fijar valores arbitrarios ni saltarse el conteo.
      allow create: if signedIn()
        && request.resource.data.count == 1
        && request.resource.data.max == 6;
      allow update: if signedIn()
        && request.resource.data.count == resource.data.count + 1
        && request.resource.data.count <= 6
        && request.resource.data.max == 6;
      allow delete: if isStaffClase();
    }

    // ── PASE DE LISTA / ASISTENCIAS (T3-E) ────────────────────────────
    //  asistencias/{uid_slotId_fecha} = { uid, slotId, fecha, marcadoPor, ts }.
    //  La marca el STAFF (Rank ≤ 2); 'marcadoPor' debe ser quien la crea. El
    //  alumno LEE SOLO LAS SUYAS (no ve la lista de nadie más). Inmutable: para
    //  corregir se borra y se vuelve a marcar.
    match /asistencias/{id} {
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isStaffClase());
      allow create: if isStaffClase()
        && request.resource.data.marcadoPor == request.auth.uid
        && request.resource.data.uid is string
        && request.resource.data.slotId is string;
      allow update: if false;
      allow delete: if isStaffClase();
    }

    // Todo lo demás: denegado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
