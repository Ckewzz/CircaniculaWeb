rules_version = '2';

// ════════════════════════════════════════════════════════════════════
//  REGLAS DE SEGURIDAD — Circanícula (Firestore)
//  Cómo aplicar:
//    Firebase Console → proyecto circanicula-267 → Firestore Database →
//    pestaña "Reglas" → pega TODO esto → "Publicar".
//
//  Principios:
//   • Créditos (Estrellas): NADIE los edita desde el cliente (ni el Creador).
//     Quedan inmutables hasta que exista un backend/Cloud Function que los
//     otorgue al comprar o por logros. (= "no editar créditos ni sensible").
//   • rank: solo el Creador (Rank 0) lo cambia.
//   • nivel/titulos/eventos (stats RPG): solo Instructoras/Creador (Rank ≤ 1).
//   • Correo: NO se guarda en Firestore (vive solo en Firebase Auth).
//   • Teléfono (usuarios_priv): solo el dueño y las instructoras (Rank ≤ 1).
//   • Pagos/reservas: privados del dueño (las instructoras los ven para agenda).
// ════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    // El super-admin se identifica por su correo verificado en el token de Auth.
    function isSuperAdmin() {
      return signedIn() && request.auth.token.email == 'treseenicos@gmail.com';
    }

    function rankDoc(uid) {
      return get(/databases/$(database)/documents/usuarios/$(uid)).data.rank;
    }
    function myRank() {
      return (signedIn() &&
              exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)))
             ? rankDoc(request.auth.uid) : 99;
    }
    function isCreador() { return isSuperAdmin() || myRank() == 0; }
    function isStaff()   { return isCreador() || myRank() == 1; }

    // Un campo no cambia, o se está inicializando por primera vez (no existía).
    function unchangedOrNew(field) {
      return !(field in resource.data) ||
             request.resource.data[field] == resource.data[field];
    }

    // ── PERFIL PÚBLICO ────────────────────────────────────────────────
    match /usuarios/{uid} {
      // Cualquier usuario autenticado puede leer perfiles públicos
      // (necesario para el futuro directorio de instructoras).
      allow read: if signedIn();

      // Crear el propio perfil. Nadie se autoasigna privilegios:
      // créditos en 0 y rank = 3 (salvo el super-admin, que nace Rank 0).
      allow create: if isOwner(uid)
        && request.resource.data.creditos == 0
        && (isSuperAdmin() || request.resource.data.rank == 3);

      // CREADOR: puede actualizar cualquier perfil (incluido rank),
      // pero NUNCA los créditos.
      allow update: if isCreador()
        && request.resource.data.creditos == resource.data.creditos;

      // STAFF (instructoras, Rank 1): otorgan stats/títulos/eventos.
      // No tocan rank ni créditos.
      allow update: if isStaff()
        && request.resource.data.rank == resource.data.rank
        && request.resource.data.creditos == resource.data.creditos;

      // DUEÑO: solo campos cosméticos. No rank, créditos, nivel, títulos,
      // eventos ni IDs (estos solo se inicializan una vez si faltaban).
      // El apodo solo se permite a Rank ≤ 2 (Instructoras/Asistentes).
      allow update: if isOwner(uid)
        && request.resource.data.rank == resource.data.rank
        && request.resource.data.creditos == resource.data.creditos
        && unchangedOrNew('nivel')
        && unchangedOrNew('titulos')
        && unchangedOrNew('eventos')
        && unchangedOrNew('userIdCorto')
        && unchangedOrNew('handle')
        && (request.resource.data.apodo == resource.data.apodo || myRank() <= 2);

      allow delete: if false;
    }

    // ── DATOS PRIVADOS (teléfono) ─────────────────────────────────────
    // Lo leen y escriben solo el dueño y las instructoras (Rank ≤ 1).
    match /usuarios_priv/{uid} {
      allow read, write: if isOwner(uid) || isStaff();
    }

    // ── CORREO DE RECUPERACIÓN (ultra-privado) ────────────────────────
    // Solo el DUEÑO lo lee/escribe. Ni las instructoras lo ven. El backend
    // (Cloud Function con admin SDK) lo leerá para enviar el link de reseteo
    // sin exponerlo nunca al cliente.
    match /usuarios_recuperacion/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── RESERVAS DE CLASES ────────────────────────────────────────────
    match /reservas/{id} {
      allow read:   if signedIn() && (resource.data.uid == request.auth.uid || isStaff());
      allow create: if isOwner(request.resource.data.uid);
      // El dueño puede marcar su reserva como activa tras el pago; staff gestiona.
      allow update: if signedIn() && (resource.data.uid == request.auth.uid || isStaff());
      allow delete: if isStaff();
    }

    // ── BOLETOS DE EVENTO (contador) ──────────────────────────────────
    match /boletos/{id} {
      allow read:   if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if isStaff();
    }

    // Todo lo demás: denegado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
